<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Common.xml">
        <edmx:Include Alias="Common" Namespace="com.sap.vocabularies.Common.v1"/>
    </edmx:Reference>
    <edmx:Reference Uri="https://oasis-tcs.github.io/odata-vocabularies/vocabularies/Org.OData.Core.V1.xml">
        <edmx:Include Alias="Core" Namespace="Org.OData.Core.V1"/>
    </edmx:Reference>
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/UI.xml">
        <edmx:Include Alias="UI" Namespace="com.sap.vocabularies.UI.v1"/>
    </edmx:Reference>
    <edmx:DataServices>
        <Schema Namespace="EmployeeService" xmlns="http://docs.oasis-open.org/odata/ns/edm">
            <Annotation Term="Core.Links">
                <Collection>
                    <Record>
                        <PropertyValue Property="rel" String="author"/>
                        <PropertyValue Property="href" String="https://cap.cloud.sap"/>
                    </Record>
                </Collection>
            </Annotation>
            <EntityContainer Name="EntityContainer">
                <EntitySet Name="Employees" EntityType="EmployeeService.Employees">
                    <NavigationPropertyBinding Path="passportDetail" Target="PassportDetails"/>
                    <NavigationPropertyBinding Path="addresses" Target="Addresses"/>
                </EntitySet>
                <EntitySet Name="PassportDetails" EntityType="EmployeeService.PassportDetails">
                    <NavigationPropertyBinding Path="employee" Target="Employees"/>
                </EntitySet>
                <EntitySet Name="Addresses" EntityType="EmployeeService.Addresses">
                    <NavigationPropertyBinding Path="employee" Target="Employees"/>
                </EntitySet>
            </EntityContainer>
            <EntityType Name="Employees">
                <Key>
                    <PropertyRef Name="ID"/>
                </Key>
                <Property Name="ID" Type="Edm.Guid" Nullable="false"/>
                <Property Name="createdAt" Type="Edm.DateTimeOffset" Precision="7"/>
                <Property Name="createdBy" Type="Edm.String" MaxLength="255"/>
                <Property Name="modifiedAt" Type="Edm.DateTimeOffset" Precision="7"/>
                <Property Name="modifiedBy" Type="Edm.String" MaxLength="255"/>
                <Property Name="name" Type="Edm.String" MaxLength="100"/>
                <Property Name="email" Type="Edm.String" MaxLength="100"/>
                <Property Name="department" Type="Edm.String" MaxLength="50"/>
                <Property Name="role" Type="Edm.String" MaxLength="50"/>
                <Property Name="salary" Type="Edm.Decimal" Precision="10" Scale="2"/>
                <NavigationProperty Name="passportDetail" Type="EmployeeService.PassportDetails" Partner="employee">
                    <OnDelete Action="Cascade"/>
                    <ReferentialConstraint Property="ID" ReferencedProperty="employee_ID"/>
                </NavigationProperty>
                <NavigationProperty Name="addresses" Type="Collection(EmployeeService.Addresses)" Partner="employee">
                    <OnDelete Action="Cascade"/>
                </NavigationProperty>
            </EntityType>
            <EntityType Name="PassportDetails">
                <Key>
                    <PropertyRef Name="ID"/>
                </Key>
                <Property Name="ID" Type="Edm.Guid" Nullable="false"/>
                <NavigationProperty Name="employee" Type="EmployeeService.Employees" Partner="passportDetail">
                    <ReferentialConstraint Property="employee_ID" ReferencedProperty="ID"/>
                </NavigationProperty>
                <Property Name="employee_ID" Type="Edm.Guid"/>
                <Property Name="passportNumber" Type="Edm.String" MaxLength="50"/>
                <Property Name="expiryDate" Type="Edm.Date"/>
                <Property Name="nationality" Type="Edm.String" MaxLength="50"/>
            </EntityType>
            <EntityType Name="Addresses">
                <Key>
                    <PropertyRef Name="ID"/>
                </Key>
                <Property Name="ID" Type="Edm.Guid" Nullable="false"/>
                <NavigationProperty Name="employee" Type="EmployeeService.Employees" Partner="addresses">
                    <ReferentialConstraint Property="employee_ID" ReferencedProperty="ID"/>
                </NavigationProperty>
                <Property Name="employee_ID" Type="Edm.Guid"/>
                <Property Name="type" Type="Edm.String" MaxLength="20"/>
                <Property Name="street" Type="Edm.String" MaxLength="255"/>
                <Property Name="city" Type="Edm.String" MaxLength="100"/>
                <Property Name="postalCode" Type="Edm.String" MaxLength="20"/>
                <Property Name="country" Type="Edm.String" MaxLength="50"/>
            </EntityType>
            <Annotations Target="EmployeeService.Employees/ID">
                <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
            </Annotations>
            <Annotations Target="EmployeeService.Employees/createdAt">
                <Annotation Term="UI.HiddenFilter" Bool="true"/>
                <Annotation Term="UI.ExcludeFromNavigationContext" Bool="true"/>
                <Annotation Term="Core.Immutable" Bool="true"/>
                <Annotation Term="Core.Computed" Bool="true"/>
                <Annotation Term="Common.Label" String="Created On"/>
            </Annotations>
            <Annotations Target="EmployeeService.Employees/createdBy">
                <Annotation Term="UI.HiddenFilter" Bool="true"/>
                <Annotation Term="UI.ExcludeFromNavigationContext" Bool="true"/>
                <Annotation Term="Core.Immutable" Bool="true"/>
                <Annotation Term="Core.Computed" Bool="true"/>
                <Annotation Term="Core.Description" String="User's unique ID"/>
                <Annotation Term="Common.Label" String="Created By"/>
            </Annotations>
            <Annotations Target="EmployeeService.Employees/modifiedAt">
                <Annotation Term="UI.HiddenFilter" Bool="true"/>
                <Annotation Term="UI.ExcludeFromNavigationContext" Bool="true"/>
                <Annotation Term="Core.Computed" Bool="true"/>
                <Annotation Term="Common.Label" String="Changed On"/>
            </Annotations>
            <Annotations Target="EmployeeService.Employees/modifiedBy">
                <Annotation Term="UI.HiddenFilter" Bool="true"/>
                <Annotation Term="UI.ExcludeFromNavigationContext" Bool="true"/>
                <Annotation Term="Core.Computed" Bool="true"/>
                <Annotation Term="Core.Description" String="User's unique ID"/>
                <Annotation Term="Common.Label" String="Changed By"/>
            </Annotations>
            <Annotations Target="EmployeeService.PassportDetails/ID">
                <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
            </Annotations>
            <Annotations Target="EmployeeService.Addresses/ID">
                <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
            </Annotations>
        </Schema>
    </edmx:DataServices>
</edmx:Edmx>