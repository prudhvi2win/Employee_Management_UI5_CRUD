<mvc:View controllerName="com.emp.employee.controller.EmployeeDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page id="detailPage" title="Employee Profile Context" showNavButton="true" navButtonPress="onNavBack">
        <content>
            <core:Fragment fragmentName="com.emp.employee.view.fragments.EmployeeForm" type="XML" />
        </content>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button text="Edit" type="Emphasized" press="onEdit" visible="{= ${viewModel>/mode} === 'view' }" />
                <Button text="Save" type="Accept" press="onSave" visible="{= ${viewModel>/mode} !== 'view' }" />
                <Button text="Delete" type="Reject" press="onDelete" visible="{= ${viewModel>/mode} === 'view' }" />
                <Button text="Cancel" type="Reject" press="onCancel" visible="{= ${viewModel>/mode} !== 'view' }" />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>