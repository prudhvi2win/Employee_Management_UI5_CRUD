<mvc:View controllerName="com.emp.employee.controller.EmployeeList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page title="Manage Employees">
        <content>
            <Table id="employeeTable" 
                   inset="false" 
                   items="{path: '/Employees'}" 
                   mode="SingleSelectMaster"
                   itemPress="onEmployeeRowPress">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Existing Employees" level="H4" />
                        <ToolbarSpacer />
                        <Button icon="sap-icon://add" text="New Employee" type="Emphasized" press="onNewEmployee" />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="Name" /></Column>
                    <Column><Text text="Email" /></Column>
                    <Column><Text text="Department" /></Column>
                    <Column width="8rem"><Text text="Salary" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation">
                        <cells>
                            <Text text="{name}" />
                            <Text text="{email}" />
                            <Text text="{department}" />
                            <Text text="{salary}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>