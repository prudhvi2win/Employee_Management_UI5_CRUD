<mvc:View controllerName="com.emp.employee.controller.EmployeeList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m" 
    xmlns:sfb="sap.ui.comp.smartfilterbar" 
    xmlns:smarttable="sap.ui.comp.smarttable" 
    class="sapUiSizeCompact"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:sv="sap.ui.comp.smartvariants">
    <sfb:SmartFilterBar id="smartFilterBar" 
                        entitySet="Employees" 
                        persistencyKey="employeeFilterKey"
                        enableBasicSearch="true"
                        search="onSearch"
                        liveMode="false"
                        basicSearchFieldName="name">        
        <sfb:controlConfiguration>
            <sfb:ControlConfiguration key="department"
                                       label="Department"
                                       visibleInAdvancedArea="true" 
                                       hasValueHelpDialog="true"/>
            <sfb:ControlConfiguration key="salary"
                                       label="Salary"
                                       visibleInAdvancedArea="true"/>
        </sfb:controlConfiguration>
    </sfb:SmartFilterBar>
    
    <smarttable:SmartTable id="employeeSmartTable"
                            entitySet="Employees"
                            smartFilterId="smartFilterBar"
                            tableType="ResponsiveTable"
                            header="Employees Data"
                            showRowCount="true"
                            useVariantManagement="true"
                            persistencyKey="employeeSmartTableKey"
                            enableAutoBinding="true"
                            editTogglable="false"
                            initiallyVisibleFields="name,department,email,salary,role"> 
        <smarttable:customToolbar>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button icon="sap-icon://add" text="New Employee" type="Emphasized" press="onNewEmployee" />
                <layoutData>
                    <FlexItemData growFactor="1" baseSize="0%"/>
                </layoutData>
            </OverflowToolbar>
        </smarttable:customToolbar>
        <Table itemPress="onEmployeeRowPress">
            <items>
                <ColumnListItem type="Navigation" />
            </items>
        </Table>
    </smarttable:SmartTable>
</mvc:View>