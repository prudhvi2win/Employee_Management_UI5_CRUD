{
  "_version": "1.84.0",
  "sap.app": {
    "id": "com.emp.employee",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.23.0",
      "toolsId": "d4f55d9d-a410-40f6-bc01-e0c59b0e0f26"
    },
    "dataSources": {
      "employeeService": {
        "uri": "/odata/v2/employee/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.149.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.emp.employee.i18n.i18n"
        }
      },
      "": {
        "dataSource": "employeeService",
        "type": "sap.ui.model.odata.v2.ODataModel",
        "preload": true,
        "settings": {
          "synchronizationMode": "None",
          "defaultBindingMode":"TwoWay",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "idSplitAppControl",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.emp.employee.view",
        "async": true
      },
      "routes": [
        {
            "name": "EmployeeList",
            "pattern": "",
            "target": ["MasterLayoutTarget", "EmployeeListTarget"]
        },
        {
            "name": "EmployeeDetail",
            "pattern": "EmployeeDetail/{id}",
            "target": ["MasterLayoutTarget", "EmployeeDetailTarget"]
        },
        {
            "name": "LeaveRequests",
            "pattern": "Workspace/LeaveRequests",
            "target": ["MasterLayoutTarget", "LeaveRequestsTarget"]
        },
        {
            "name": "UploadResumes",
            "pattern": "Workspace/UploadResumes",
            "target": ["MasterLayoutTarget", "UploadResumesTarget"]
        }
      ],
      "targets": {
        "MasterLayoutTarget": {
            "viewName": "Master",
            "controlAggregation": "masterPages",
            "id": "idMasterView"
        },
        "EmployeeListTarget": {
        "viewName": "EmployeeList",
        "controlAggregation": "detailPages"
        },
        "EmployeeDetailTarget": {
        "viewName": "EmployeeDetail",
        "controlAggregation": "detailPages"
        },
        "LeaveRequestsTarget": {
            "viewName": "LeaveRequests",
            "controlAggregation": "detailPages",
            "id": "idLeaveRequests"
        },
        "UploadResumesTarget": {
            "viewName": "UploadResumes",
            "controlAggregation": "detailPages",
            "id": "idUploadResumes"
        }
      }
    },
    "rootView": {
      "viewName": "com.emp.employee.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
